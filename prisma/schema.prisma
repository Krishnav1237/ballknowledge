datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


// ─── Football IQ Match-Centric Models ─────────────────────────────────────────

model FootballIQProfile {
  id               String            @id @default(uuid())
  username         String            @unique
  email            String?           @unique           // Save user's email from Google Auth
  name             String?                             // Save user's full name from Google Auth
  avatarStyle      String            @default("fun-emoji")
  avatarSeed       String
  favoriteClub     String?
  favoriteNation   String?
  overallRating    Int               @default(50)
  predictionRating Int               @default(50)  // PRD — Predictor Score (0-100)
  hotTakeRating    Int               @default(50)  // HOT — Hot Take Score (0-100)
  managerRating    Int               @default(50)  // MGR — Manager Score (0-99)
  roastScore       Int               @default(50)  // RST — Roast Score (50-100)
  role             String            @default("FREE") // "FREE" | "PREMIUM" | "ADMIN"
  season           String            @default("World Cup 2026")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  passwordHash     String?
  inputImage       String?           // Save the user's original uploaded face photo base64
  predictions      MatchPrediction[]
  matchCards       MatchCard[]
  chatMessages     ChatMessage[]

  @@index([overallRating(sort: Desc)])
  @@index([predictionRating(sort: Desc)])
  @@index([hotTakeRating(sort: Desc)])
}

model MatchPrediction {
  id                String            @id @default(uuid())
  profileId         String
  profile           FootballIQProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  matchId           String
  homeScore         Int
  awayScore         Int
  firstGoalscorer   String
  motm              String
  possessionWinner  String
  createdAt         DateTime          @default(now())
  hotTakes          HotTake[]

  @@unique([profileId, matchId])
}

model HotTake {
  id             String          @id @default(uuid())
  predictionId   String
  prediction     MatchPrediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  statement      String
  confidence     Int             // 1-5
  createdAt      DateTime        @default(now())
}

model ChatMessage {
  id          String            @id @default(uuid())
  matchId     String
  profileId   String
  profile     FootballIQProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  text        String
  isRoast     Boolean           @default(false)
  upvotes     Int               @default(0)
  downvotes   Int               @default(0)
  createdAt   DateTime          @default(now())

  @@index([profileId, matchId])
  @@index([matchId, createdAt])
}

model MatchCard {
  id              String            @id @default(uuid())
  profileId       String
  profile         FootballIQProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  matchId         String
  rating          Int               // Match OVR score (0-99)
  verdict         String            // e.g. "Guilty" | "Acquitted"
  charge          String            // e.g. "Delusion Merchant" | "Certified Chef"
  evidence        String
  sentence        String
  rarity          String            // COMMON | RARE | EPIC | LEGENDARY
  statsJson       Json              // { prd, mgr, hot, rst, ovr } V1 scores
  cardTheme       String?
  aiImageUrl      String?
  createdAt       DateTime          @default(now())

  @@unique([profileId, matchId])
}
