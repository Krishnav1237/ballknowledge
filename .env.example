# Database Connection URL (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/football_court?schema=public"

# AI Inference Keys for Grading Hot Takes + Image Generation
# At least one key is recommended. OpenRouter also powers viral card image generation.
OPENROUTER_API_KEY="sk-or-v1-your_openrouter_key_here"
GROQ_API_KEY="gsk_your_groq_api_key_here"
NVIDIA_API_KEY="nvapi-your_nvidia_api_key_here"

# Configurable Image Generation Provider & Settings
# Options: "openrouter" (default) or "fal"
IMAGE_GENERATION_PROVIDER="openrouter"
OPENROUTER_IMAGE_MODEL="black-forest-labs/flux-1-pro"
FAL_API_KEY="fal_key_here"


# App Settings
NODE_ENV="development"
PORT=3000

# Public site URL — used for OG image metadata and sitemap generation
# Set this to your deployed domain in production (e.g., https://ballknowledge.vercel.app)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
