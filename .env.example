# Database Connection URL (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/football_court?schema=public"

# AI Inference Keys for Grading Hot Takes & Image Generation
# At least one key is recommended. OpenRouter is required for AI Trading Card image generation.
OPENROUTER_API_KEY="sk-or-v1-your_openrouter_key_here"
GROQ_API_KEY="gsk_your_groq_api_key_here"
NVIDIA_API_KEY="nvapi-your_nvidia_api_key_here"

# Configurable Image Generation Settings (OpenRouter Only)
OPENROUTER_IMAGE_MODEL="black-forest-labs/flux.2-pro"

# Credentials/session authentication secrets
# Set unique random strings in production. AUTH_SECRET signs HTTP-only session cookies.
AUTH_SALT="ball_knowledge_salt_secret_2026"
AUTH_SECRET="replace_with_at_least_32_random_bytes"

# Google OAuth client ID for the custom Google sign-in flow
NEXT_PUBLIC_GOOGLE_CLIENT_ID="1047514336049-7gr11k2iirfphv7242m8u8v83q89k6e8.apps.googleusercontent.com"

# App Settings
NODE_ENV="development"
PORT=3000

# Public site URL — used for OG image metadata and sitemap generation
# Set this to your deployed domain in production (e.g., https://ballknowledge.live)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
